# Laptop preset for opencode-search-engine
# Conservative resource limits tuned for shared/battery-constrained environments.
# Usage: source .env.laptop && ./start.sh
#        or: env $(cat .env.laptop | grep -v '^#' | xargs) ./start.sh

# ---------------------------------------------------------------------------
# Indexer (Rust) — thread pool limits
# ---------------------------------------------------------------------------

# Rayon parallel threads (file hashing, LanceDB I/O): max(2, cpus/2) is default.
# Force to 2 on a laptop to leave cores for IDE / browser.
OPENCODE_SEARCH_RAYON_THREADS=2

# Tokio async worker threads (network I/O, timers): 2 is enough for local service.
TOKIO_WORKER_THREADS=2

# BLAS/LAPACK/OpenMP thread limits: keep at 1-2 for background service.
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1

# ---------------------------------------------------------------------------
# Indexer — file size limits
# ---------------------------------------------------------------------------

# Max file size to index (KB). Applied to ALL categories uniformly.
# Default per-category limits: source=10240KB, text=2048KB, unknown=1024KB.
# 512KB is enough to catch most real source files; skips generated/minified blobs.
OPENCODE_SEARCH_MAX_FILE_SIZE_KB=512

# ---------------------------------------------------------------------------
# Indexer — storage cache
# ---------------------------------------------------------------------------

# Max LanceDB connections held open. Each costs ~10-15 MB RSS.
# Default (without env) is 10. Reduce to 6 for very constrained laptops.
OPENCODE_SEARCH_STORAGE_CACHE_SIZE=8

# ---------------------------------------------------------------------------
# Indexer — compaction (reduce background I/O)
# ---------------------------------------------------------------------------

# Wait 5 minutes of idle before compacting (default 30s).
OPENCODE_COMPACTION_IDLE_MS=300000

# Require at least 100 ops before compacting (default 50).
OPENCODE_COMPACTION_OPS_THRESHOLD=100

# Force-compact after 500 ops max (default 200).
OPENCODE_COMPACTION_FORCE_THRESHOLD=500

# Check compaction every 10 minutes (default 5 min).
OPENCODE_COMPACTION_CHECK_INTERVAL_MS=600000

# Per-DB compaction cooldown: 2 hours (default 1h).
OPENCODE_INDEXER_COMPACTION_COOLDOWN_SECS=7200

# Space between consecutive compactions: 30s (default 5s) to ease disk I/O.
OPENCODE_INDEXER_COMPACTION_SPACING_SECS=30

# ---------------------------------------------------------------------------
# Indexer — embed concurrency
# ---------------------------------------------------------------------------

# Max concurrent embedding requests from indexer → embedder (default 3).
# Reduce to 1 to avoid saturating CPU embedder on low-end hardware.
OPENCODE_INDEXER_EMBED_CONCURRENCY=1

# Max concurrent linked-project indexing jobs (default 4).
OPENCODE_INDEXER_LINK_CONCURRENCY=1

# ---------------------------------------------------------------------------
# Indexer — idle shutdown
# ---------------------------------------------------------------------------

# Auto-shutdown indexer after 5 minutes idle (default 10min). Saves RAM when not coding.
OPENCODE_INDEXER_IDLE_SHUTDOWN=300

# ---------------------------------------------------------------------------
# Embedder (Python) — worker pool and memory
# ---------------------------------------------------------------------------

# Number of ONNX inference workers. 1 = sequential (lowest RAM, suitable for CPU mode).
OPENCODE_EMBED_WORKERS=1

# RSS soft limit: trigger gc.collect() if embedder exceeds this (MB).
# Hard limit is 1.5x this value; exceeding it triggers restart.
OPENCODE_SEARCH_EMBEDDER_MAX_RSS_MB=768

# Idle shutdown for embedder process (seconds). 5 minutes.
OPENCODE_EMBED_IDLE_SHUTDOWN=300

# Max concurrent active requests before circuit breaker rejects (default 32).
OPENCODE_EMBED_MAX_ACTIVE=8

# Batch coalescing: smaller batches for lower latency on laptop (default 384).
OPENCODE_COALESCE_BATCH=64
OPENCODE_COALESCE_WAIT_MS=20
